# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DB"

# NextAuth.js
# Generate a secret using: openssl rand -base64 32
AUTH_SECRET="REPLACE_ME"
# Must be set to "true" for non-Vercel deployments to prevent OAuth/callback errors (UntrustedHost)
AUTH_TRUST_HOST="true"

# GitHub OAuth (https://github.com/settings/developers)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Microsoft Entra ID (Azure AD)
AUTH_MICROSOFT_ENTRA_ID_CLIENT_ID=""
AUTH_MICROSOFT_ENTRA_ID_CLIENT_SECRET=""
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID=""

# Upstash Redis (Rate Limiting)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# App URL
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"

# Password hashing rounds (default: 14, recommended for security)
BCRYPT_ROUNDS="14"

# hCaptcha (Bot detection, optional)
# Register at: https://dashboard.hcaptcha.com/ -> Add Site -> Get Site Key / Secret
#
# To disable: Leave HCAPTCHA_SECRET unset to skip validation entirely (for development).
# Local bypass: Set HCAPTCHA_BYPASS=true to force skip (DO NOT set this in production).
# Server-side secret (KEEP SECRET, do not expose to the frontend)
HCAPTCHA_SECRET=""
# Frontend sitekey (visible to the browser, requires NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_HCAPTCHA_SITEKEY=""
# Set to "true" to skip validation (only for local development/testing)
# HCAPTCHA_BYPASS="false"