# Database
DATABASE_URL="postgresql://user:password@host:6543/db?pgbouncer=true&sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/db&sslmode=require"

# NextAuth.js - Generate with: openssl rand -base64 33
AUTH_SECRET="generate_with_openssl_rand_base64_33"

# GitHub OAuth
AUTH_GITHUB_ID="your_github_client_id"
AUTH_GITHUB_SECRET="your_github_client_secret"

# Microsoft Entra ID (Azure AD)
AUTH_MICROSOFT_ENTRA_ID_CLIENT_ID="your_client_id"
AUTH_MICROSOFT_ENTRA_ID_CLIENT_SECRET="your_client_secret"
AUTH_MICROSOFT_ENTRA_ID_ISSUER="https://login.microsoftonline.com/<tenant-id>/v2.0/"

# Upstash Redis (Rate Limiting) - REQUIRED in production
UPSTASH_REDIS_REST_URL="https://your-region.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_token"

# App URL - Must be HTTPS in production
NEXTAUTH_URL="http://localhost:3000"

# Password hashing rounds (default: 14, recommended for security)
BCRYPT_ROUNDS="14"